{
  "format_version": "1.20.80",
  "minecraft:entity": {
    "description": {
      "identifier": "lagfixer:item_collector",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "lagfixer:active": {
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 1,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "operator": "==",
                "value": "item"
              }
            }
          ],
          "within_radius": 8
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["inanimate"]
      },
      "minecraft:collision_box": {
        "width": 0.5,
        "height": 0.5
      },
      "minecraft:health": {
        "value": 100,
        "max": 100
      },
      "minecraft:timer": {
        "looping": true,
        "time": [2, 4]
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["lagfixer:active"]
        }
      }
    }
  }
}
